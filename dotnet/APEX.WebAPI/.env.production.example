# ============================================================
# APEX — Variables d'environnement pour la PRODUCTION
# ============================================================
# Copiez ce fichier et renseignez vos valeurs.
# Ces variables surclassent automatiquement appsettings.json
# grâce à builder.Configuration.AddEnvironmentVariables().
#
# ⚠️  Ne jamais committer ce fichier avec de vraies valeurs !
# ============================================================

# --- Gemini AI ---
# Créez un compte Google Cloud séparé pour la prod (pas votre clé perso)
Gemini__ApiKey=VOTRE_CLE_GEMINI_PROD

# --- JWT Secret ---
# Minimum 64 caractères aléatoires — générez avec:
#   openssl rand -base64 64
Jwt__Secret=VOTRE_SECRET_JWT_64CHARS_MIN

# --- Base de données SQLite (ou SQL Server en prod) ---
# ConnectionStrings__ApexDb=Data Source=/var/data/apex_prod.db

# --- France Travail (inchangé si vous gardez les mêmes scopes) ---
# FranceTravailApi__ClientId=PAR_xxx
# FranceTravailApi__ClientSecret=xxx

# --- SMTP (email de vérification) ---
# Smtp__Host=smtp.sendgrid.net
# Smtp__Port=587
# Smtp__User=apikey
# Smtp__Password=VOTRE_CLE_SENDGRID

# --- CORS (domaine de prod) ---
# Ajoutez votre domaine dans appsettings.Production.json
# "Cors": { "AllowedOrigins": ["https://apex.avers.fr"] }
